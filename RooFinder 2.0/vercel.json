{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.js"
    },
    {
      "src": "/dashboard$",
      "dest": "/dashboard.html"
    },
    {
      "src": "/reset-password$",
      "dest": "/reset-password.html"
    },
    {
      "src": "/auth\\.js$",
      "dest": "/auth.js"
    },
    {
      "src": "/$",
      "dest": "/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}